generator client {
  provider     = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model UserAcademicRegistration {
  id                 Int                              @id @default(autoincrement())
  name               String
  password           String
  role               Role                             @default(USER)

  createdAt          DateTime                         @default(now())
  updatedAt          DateTime                         @updatedAt

  lecturerCourses    CourseAcademicRegistration[]
  lecturerApprovals  EnrollmentAcademicRegistration[] @relation("LecturerApprovals")
  studentEnrollments EnrollmentAcademicRegistration[] @relation("StudentEnrollments")

  batches            EnrollmentBatch[]
}

model CourseAcademicRegistration {
  id          Int                              @id @default(autoincrement())
  name        String
  code        String                           @unique
  stock       Int

  createdAt   DateTime                         @default(now())
  updatedAt   DateTime                         @updatedAt
  
  lecturerId  Int
  lecturer    UserAcademicRegistration         @relation(fields: [lecturerId], references: [id])
  enrollments EnrollmentAcademicRegistration[]
}

model EnrollmentAcademicRegistration {
  id         Int                        @id @default(autoincrement())
  batchId    Int
  studentId  Int
  courseId   Int
  lecturerId Int

  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt

  batch      EnrollmentBatch            @relation(fields: [batchId], references: [id])
  course     CourseAcademicRegistration @relation(fields: [courseId], references: [id])
  lecturer   UserAcademicRegistration   @relation("LecturerApprovals", fields: [lecturerId], references: [id])
  student    UserAcademicRegistration   @relation("StudentEnrollments", fields: [studentId], references: [id])

  @@unique([studentId, courseId])
}

model EnrollmentBatch {
  id        Int @id @default(autoincrement())

  studentId Int
  status    EnrollmentBatchStatus @default(DRAFT)

  student   UserAcademicRegistration @relation(fields: [studentId], references: [id])
  items     EnrollmentAcademicRegistration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  LECTURER
}

enum EnrollmentBatchStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}
